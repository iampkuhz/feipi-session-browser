.DS_Store

# Runtime output
output/
data/

# Python
.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# SQLite index
*.sqlite
*.sqlite3

# Personal config
.claude/settings.local.json
.mcp.json
.env

# Agent runtime state
.agent/

# IDE
.idea/
.vscode/

# OpenSpec change artifacts (tracked locally, not committed)
# .gitkeep keeps the directory itself trackable
openspec/changes/*
!openspec/changes/.gitkeep

# Harness archive
/harness/archive/

# Prompts (input definitions, not authoritative)
/prompts/

# Reports
reports/

# Exports
*.mhtml
*.mht
*.zip
*.tar
*.tar.gz

# Playwright
test-results/
playwright-report/
blob-report/
playwright/.cache/

# Node
node_modules/
