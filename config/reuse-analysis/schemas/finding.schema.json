{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schemaVersion",
    "findings"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "severity",
          "kind",
          "fingerprint",
          "occurrences",
          "touchesChangedCode",
          "suggestedDecisions"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "severity": {
            "enum": ["P0", "P1", "P2", "P3"]
          },
          "kind": {
            "type": "string"
          },
          "fingerprint": {
            "type": "string"
          },
          "occurrences": {
            "type": "array",
            "minItems": 1
          },
          "touchesChangedCode": {
            "type": "boolean"
          },
          "suggestedDecisions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "ownership": {
            "type": "object"
          },
          "peerGroup": {
            "type": ["string", "null"]
          }
        }
      }
    }
  }
}
