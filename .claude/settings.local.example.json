{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Personal local override. Copy to .claude/settings.local.json when you want Claude Code to run this repo with minimal prompts. This example is safe to commit; .claude/settings.local.json stays gitignored.",
  "agent": "qwen-main-default",
  "permissions": {
    "allow": [],
    "ask": [],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(.mcp.json)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gh/hosts.yml)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fdx:*)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(chmod -R 777 /:*)",
      "Bash(dd if=* of=/dev/*)"
    ],
    "defaultMode": "bypassPermissions",
    "skipDangerousModePermissionPrompt": true
  },
  "env": {
    "SESSION_BROWSER_DEV_MODE": "1",
    "FEIPI_AGENT_LOGS_BASE": "tmp/agent_logs"
  }
}
