{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "additionalDirectories": [
      "/Users/zhehan/Downloads/feipi_session_browser_harness_seed2",
      "/Users/zhehan/Documents/tools/llm/feipi-session-browser"
    ],
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "MultiEdit(*)",
      "Glob(*)",
      "Grep(*)",
      "LS(*)",
      "Task(*)",
      "TodoWrite(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "NotebookRead(*)",
      "NotebookEdit(*)",
      "BashOutput(*)",
      "KillBash(*)",
      "ExitPlanMode(*)",
      "TaskCreate(*)"
    ],
    "ask": [],
    "deny": []
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 scripts/agent_hooks/inject_session_context.py"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 scripts/agent_hooks/inject_session_context.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre_tool_guard.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 scripts/agent_hooks/guard_active_openspec_change.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post_tool_guard.sh"
          },
          {
            "type": "command",
            "command": "python3 scripts/agent_hooks/log_change_evidence.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/stop_check.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 scripts/agent_hooks/stop_validate_change.py"
          }
        ]
      }
    ]
  }
}
